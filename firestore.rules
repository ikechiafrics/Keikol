rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn()
                  && (request.auth.uid == resource.data.userId || isAdmin());

      allow create: if isSignedIn()
                    && request.auth.uid == request.resource.data.userId
                    && request.resource.data.status == "pending_payment";

      // Admins can update a booking's status/contract amount freely. The
      // owner may also update status directly, but only for two narrow,
      // self-service transitions: cancelling outright while nothing has
      // been invoiced yet (pending_payment/under_review), or flagging a
      // confirmed booking for admin-mediated cancellation (since a
      // confirmed campaign may already have invoices/payment involved,
      // which this app can't unwind automatically).
      allow update: if (isAdmin()
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "updatedAt", "contractAmount"])
                        && request.resource.data.status in ["pending_payment", "under_review", "confirmed", "cancellation_requested", "cancelled"])
                    || (isSignedIn()
                        && request.auth.uid == resource.data.userId
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "updatedAt"])
                        && ((resource.data.status in ["pending_payment", "under_review"] && request.resource.data.status == "cancelled")
                            || (resource.data.status == "confirmed" && request.resource.data.status == "cancellation_requested")));

      // Only cancelled bookings can be deleted — anything still active
      // (pending, under review, confirmed, or awaiting a cancellation
      // decision) must go through a status change first.
      allow delete: if isAdmin() && resource.data.status == "cancelled";
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public-safe mirror of confirmed booking date ranges — only the fields
    // needed to compute billboard availability for anonymous visitors.
    // Never write contact/campaign/user data here.
    match /publicBookingWindows/{windowId} {
      allow read: if true;
      allow create, update: if isAdmin()
                            && request.resource.data.keys().hasOnly(["billboardId", "startDate", "endDate", "status"])
                            && request.resource.data.status == "confirmed";
      allow delete: if isAdmin();
    }

    match /billboards/{billboardId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Invoices are manually created/managed by admins only (no payment
    // gateway — amounts and paid/unpaid status are recorded by hand). Every
    // invoice for a given bookingId shares that booking's userId, so a
    // customer's query for their own booking's invoices always satisfies
    // this read rule for every result, and is denied outright for anyone
    // else's booking.
    match /invoices/{invoiceId} {
      allow read: if isSignedIn()
                  && (request.auth.uid == resource.data.userId || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    // Quote requests are submitted anonymously from /contact — there is no
    // signed-in identity to lean on, so this create rule is the entire
    // security boundary: it fully validates shape/types/sizes and forces
    // status/timestamps itself, unlike every other write path above.
    match /quoteRequests/{quoteId} {
      allow read: if isAdmin();

      allow create: if request.resource.data.keys().hasOnly([
                        "name", "company", "email", "phone", "city",
                        "billboardType", "budget", "duration", "goal", "message",
                        "billboardId", "interestedBillboard", "status", "createdAt", "updatedAt"
                      ])
                    && request.resource.data.keys().hasAll([
                        "name", "company", "email", "phone", "city",
                        "billboardType", "budget", "duration", "goal", "message",
                        "billboardId", "interestedBillboard", "status", "createdAt", "updatedAt"
                      ])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 200
                    && request.resource.data.company is string && request.resource.data.company.size() <= 200
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 0 && request.resource.data.email.size() <= 320
                    && request.resource.data.phone is string && request.resource.data.phone.size() <= 40
                    && request.resource.data.city is string && request.resource.data.city.size() <= 100
                    && request.resource.data.billboardType is string && request.resource.data.billboardType.size() <= 100
                    && request.resource.data.budget is string && request.resource.data.budget.size() <= 100
                    && request.resource.data.duration is string && request.resource.data.duration.size() <= 100
                    && request.resource.data.goal is string && request.resource.data.goal.size() <= 200
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0 && request.resource.data.message.size() <= 5000
                    && request.resource.data.billboardId is string && request.resource.data.billboardId.size() <= 200
                    && request.resource.data.interestedBillboard is string
                    && request.resource.data.interestedBillboard.size() > 0
                    && request.resource.data.interestedBillboard.size() <= 200
                    && request.resource.data.status == "new"
                    && request.resource.data.createdAt == request.time
                    && request.resource.data.updatedAt == request.time;

      allow update: if isAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "updatedAt"])
                    && request.resource.data.status in ["new", "contacted", "closed"]
                    && request.resource.data.updatedAt == request.time;

      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
