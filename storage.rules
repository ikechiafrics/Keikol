rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /artwork/{userId}/{allPaths=**} {
      // Admins can also read/write here — needed so they can view a
      // customer's artwork, or attach it on the customer's behalf (e.g. a
      // phoned-in booking where the file arrives by email afterward).
      allow read: if request.auth != null
                  && (request.auth.uid == userId
                      || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin");
      allow write: if request.auth != null
                   && (request.auth.uid == userId
                       || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin")
                   && request.resource.size < 20 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf');
    }
    match /billboards/{billboardId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin"
                   && request.resource.size < 20 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    match /photographers/{photographerId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin"
                   && request.resource.size < 20 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
